# Ethereum WebSocket RPC (required for real-time events)
# Providers: Alchemy, Infura, QuickNode
ETH_WS_RPC=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Ethereum HTTP RPC (optional - reduces WebSocket load for metadata calls)
ETH_HTTP_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Server port
PORT=3000
